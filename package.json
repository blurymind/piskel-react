    "@tanstack/react-router": "^1.122.0",
    "@uidotdev/usehooks": "^2.4.1",
    "ace-builds": "^1.43.5",
    "ace-diff": "^3.0.3",
    "classnames": "^2.5.1",
    "react": "^19.0.0",
    "react-accessible-treeview": "^2.11.2",
    "react-ace": "^14.0.1",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.2",
    "react-split-pane": "^3.0.5",
    "string-to-react-component": "^4.0.1",
